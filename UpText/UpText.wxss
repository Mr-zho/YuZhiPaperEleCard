.container {
    padding: 20px;
  }
  
  .input-box {
    width: 100%;
    height: 150px;
    border: 1px solid #ccc;
    padding: 10px;
    font-size: 16px;
    margin-bottom: 20px;
    box-sizing: border-box;
  }
  
  .send-btn {
    width: 100%;
    padding: 10px;
    background-color: #1aad19;
    color: #fff;
    font-size: 16px;
    border: none;
    border-radius: 5px;
  }